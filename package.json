{
  "name": "db-agent-mcp",
  "version": "1.0.0",
  "description": "基于 MCP 的数据库智能代理，支持 MySQL/PostgreSQL/SQLite",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "db-agent-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "database",
