# DB Agent MCP - 环境变量配置示例

# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_USER=root
MYSQL_PASS=password

MYSQL_PROD_HOST=db.company.com
MYSQL_PROD_USER=analyst
MYSQL_PROD_PASS=secret_password

# ============================================
# PostgreSQL 数据库配置
# ============================================
PG_USER=postgres
PG_PASS=local_dev_pass

# ============================================
# SQLite 配置（可选，直接在YAML中指定路径）
# ============================================
# SQLITE_DATA_PATH=./data

# ============================================
# 应用配置
# ============================================
# 配置文件路径（默认为 ./config/databases.yaml）
DB_CONFIG_PATH=./config/databases.yaml

# 日志级别: debug, info, warn, error
LOG_LEVEL=info
